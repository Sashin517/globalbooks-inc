<?xml version="1.0" encoding="utf-8" ?>
<wsdl:definitions 
    targetNamespace="http://globalbooks.com/bpel/placeorder"
    xmlns="http://schemas.xmlsoap.org/wsdl/"
    xmlns:tns="http://globalbooks.com/bpel/placeorder"
    xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" 
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
    xmlns:plnk="http://docs.oasis-open.org/wsbpel/2.0/plnktype">

    <wsdl:message name="PlaceOrderMessage">
        <wsdl:part name="payload" type="xsd:string"/>
    </wsdl:message>

    <wsdl:portType name="PlaceOrderPortType">
        <wsdl:operation name="processOrder">
            <wsdl:input message="tns:PlaceOrderMessage"/>
            <wsdl:output message="tns:PlaceOrderMessage"/>
        </wsdl:operation>
    </wsdl:portType>

    <wsdl:binding name="PlaceOrderBinding" type="tns:PlaceOrderPortType">
        <soap:binding style="rpc" transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="processOrder">
            <soap:operation soapAction="" style="rpc"/>
            <wsdl:input><soap:body namespace="http://globalbooks.com/bpel/placeorder" use="literal"/></wsdl:input>
            <wsdl:output><soap:body namespace="http://globalbooks.com/bpel/placeorder" use="literal"/></wsdl:output>
        </wsdl:operation>
    </wsdl:binding>

    <wsdl:service name="PlaceOrderService">
        <wsdl:port name="PlaceOrderPort" binding="tns:PlaceOrderBinding">
            <soap:address location="http://localhost:8080/ode/processes/PlaceOrderProcess"/>
        </wsdl:port>
    </wsdl:service>

    <plnk:partnerLinkType name="PlaceOrderPartnerLinkType">
        <plnk:role name="me" portType="tns:PlaceOrderPortType"/>
    </plnk:partnerLinkType>
</wsdl:definitions>